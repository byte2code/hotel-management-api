# Database configuration (Azure MySQL datasource)
DATASOURCE_URL=jdbc:mysql://ajaydemosqlserver.mysql.database.azure.com:3306/hotel?sessionVariables=sql_mode='NO_ENGINE_SUBSTITUTION'&jdbcCompliantTruncation=false&DB_CLOSE_ON_EXIT=FALSE
DATASOURCE_USERNAME=demouser
DATASOURCE_PASSWORD=changeme

# Keycloak security configuration
KEYCLOAK_CLIENT_SECRET=changeme
KEYCLOAK_ISSUER_URI=https://lemur-12.cloud-iam.com/auth/realms/hotel-demo
KEYCLOAK_AUTH_SERVER_URL=https://lemur-12.cloud-iam.com/auth

# Google OAuth credentials (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redis cache server configuration
REDIS_HOST=localhost
REDIS_PORT=6379
